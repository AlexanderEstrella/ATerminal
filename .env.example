# ATerminal uses ~/.aterminal/server.json and ~/.aterminal/agent.json.
# Create those files with:
#   aterminal server init
#   aterminal agent enroll --server <url> --token <token>

# Development-only escape hatch for plain HTTP remote agent URLs.
# Do not set this for internet-exposed deployments.
ATERMINAL_ALLOW_INSECURE_REMOTE=0

# Optional: override the default ~/.aterminal config directory.
# ATERMINAL_CONFIG_DIR=C:\Users\you\.aterminal
